# supply-chain cooldown: don't *resolve* deps published less than a day ago.
# A no-op for `npm ci` (lockfile install); protects `npm install`/`npm update`.
# Requires npm 11.x; older npm silently ignores it.
min-release-age=1

# ...except our own scopes: these are self-published, so the cooldown's threat model
# (someone else's compromised publish) doesn't apply -- never withhold them.
# `min-release-age-exclude` accepts globs; verified on npm 11.18.
min-release-age-exclude[]=@ipsme/*
min-release-age-exclude[]=@knev/*
